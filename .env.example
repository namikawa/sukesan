# Google OAuth (Google Cloud Console で取得)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (Azure Portal のアプリ登録で取得)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# 個人/複数テナントを許可する場合は common のままでよい。単一テナントならテナント ID を指定。
MS_TENANT_ID=common

# 管理者パスワード（設定画面・カレンダー連携・Outlook 同期の保護に使用）
ADMIN_PASSWORD=

# セッション署名用の秘密鍵。本番（APP_ENV/RACK_ENV=production）では必須。
# 開発時は未設定でも起動時に一時生成される（再起動で無効化）。
# 生成例: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
SESSION_SECRET=

# 保存する Google トークンの暗号化鍵。本番では必須。
# 開発時は未設定なら SESSION_SECRET から導出する。
# この鍵を変更・紛失すると既存の保存トークンは復号できなくなる（再連携が必要）。
# 生成例: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
TOKEN_ENCRYPTION_KEY=

# 任意: 実行環境。production を指定すると HTTPS 必須・Cookie の Secure 化・
# 詳細エラー非表示などの本番ハードニングが有効になる（既定は development）。
# APP_ENV=production

# 任意: アプリの公開 URL（スキーム + ホスト）。本番では設定推奨。
# OAuth の redirect_uri 等の生成に使い、Host ヘッダ汚染の影響を排除する。
# 未設定の場合はリクエストから組み立てる（開発向け）。
# APP_BASE_URL=https://example.com

# 任意: 起動ポート（既定 3000）
# PORT=3000
