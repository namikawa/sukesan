# Google OAuth (Google Cloud Console で取得)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (Azure Portal のアプリ登録で取得)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# 個人/複数テナントを許可する場合は common のままでよい。単一テナントならテナント ID を指定。
MS_TENANT_ID=common

# 管理者パスワードの bcrypt ダイジェスト（設定画面・カレンダー連携・Outlook 同期の保護に使用）。
# 平文ではなくハッシュを設定する。生成: bin/admin_password_digest
# 値に $ を含むため、必ずシングルクォートで囲む（dotenv の変数展開を防ぐ）。
# 例: ADMIN_PASSWORD_DIGEST='$2a$12$....'
ADMIN_PASSWORD_DIGEST=

# セッション署名用の秘密鍵。本番（APP_ENV/RACK_ENV=production）では必須。
# 開発時は未設定でも起動時に一時生成される（再起動で無効化）。
# 生成例: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
SESSION_SECRET=

# 保存する Google トークンの暗号化鍵。本番では必須。
# 開発時は未設定なら SESSION_SECRET から導出する。
# この鍵を変更・紛失すると既存の保存トークンは復号できなくなる（再連携が必要）。
# 生成例: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
TOKEN_ENCRYPTION_KEY=

# 任意: 実行環境。production を指定すると HTTPS 必須・Cookie の Secure 化・
# 詳細エラー非表示などの本番ハードニングが有効になる（既定は development）。
# APP_ENV=production

# アプリの公開 URL（スキーム + ホスト）。本番（APP_ENV=production）では必須（未設定だと起動失敗）。
# OAuth の redirect_uri やチケット URL の生成に使い、Host ヘッダ汚染の影響を排除する。
# 開発では未設定でも可（リクエストから組み立てる）。
# APP_BASE_URL=https://example.com

# 任意: 起動ポート（既定 3000）
# PORT=3000

# 任意: タイムゾーン（既定 Asia/Tokyo）。空き時間の算出・表示・入力の解釈に使う。
# tz database 名で指定（例: Asia/Tokyo, America/New_York）。サーバ OS の設定に依存させないため固定推奨。
# APP_TIMEZONE=Asia/Tokyo

# データストアの種類（既定 file）。
#   file      : data/ 配下のローカルファイル（単一ホスト前提。開発・VM 運用向け）
#   firestore : Google Cloud Firestore（Cloud Run など複数インスタンス・サーバレス向け）
# STORE_BACKEND=file

# STORE_BACKEND=firestore のときのプロジェクト ID。Cloud Run では通常 GOOGLE_CLOUD_PROJECT が
# 自動設定されるため不要。明示する場合のみ設定する。
# FIRESTORE_PROJECT_ID=

# ローカルで Firestore エミュレータに接続する場合のホスト（本番では設定しない）。
# 例: gcloud emulators firestore start --host-port=localhost:8085
# FIRESTORE_EMULATOR_HOST=localhost:8085

# 前段プロキシ（Cloud Run・ロードバランサ等）の背後で動かす場合は true。
# X-Forwarded-For（レート制限の IP 判定）と X-Forwarded-Proto（HTTPS 判定・リダイレクト）を信頼する。
# 直接公開する場合は設定しない（ヘッダ偽装を防ぐため信頼はオプトイン）。
# APP_TRUST_PROXY=true

# アクセスログ・監査ログの出力先を stdout にする（Cloud Run などコンテナ環境向け。
# プラットフォームがログを収集する前提。未設定なら log/ 配下のファイルへ週次ローテーション出力）。
# LOG_TO_STDOUT=true

# 任意: ゲスト操作（予約・仮押さえ・決定・全取りやめ）を管理者の Slack へ通知する Incoming Webhook URL。
# 未設定・空なら通知しない。設定すると各操作時に依頼者名・件名・日時を含むメッセージが投稿される。
# 取得: Slack アプリの Incoming Webhooks を有効化して発行する。URL は秘密情報として扱う。
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# 任意: Slack 通知の本文先頭に付けるメンション。channel（@channel）/ here（@here）/
# メンバー ID（U… または W…）を指定できる。未設定・不正値ならメンションなし。
# SLACK_MENTION=channel

# 任意: 外部 API（Google/Microsoft）呼び出しのタイムアウト秒（既定: 接続 5 / 読み取り 15）。
# 通常は変更不要。回線・環境に合わせて調整する場合のみ設定する。
# HTTP_OPEN_TIMEOUT=5
# HTTP_READ_TIMEOUT=15
