<%== page_header(title: "設定", logout: true) %>

<nav class="breadcrumb" aria-label="breadcrumbs">
  <ul>
    <li><a href="/">トップ</a></li>
    <li><a href="/admin">管理者トップ</a></li>
    <li><a href="/tickets">Google カレンダー調整ツール</a></li>
    <li class="is-active"><a href="#" aria-current="page">設定</a></li>
  </ul>
</nav>

<%== flash_messages %>

<h2 class="title is-5">Google カレンダー連携</h2>
<p class="block">ワンタイム URL の利用者は、ここで連携した管理者カレンダーに対して予定を登録します。</p>
<div class="box">
  <div class="level is-mobile">
    <div class="level-left">
      <div class="level-item">
        Google カレンダー
        <span class="tag <%= google_connected? ? "is-success" : "is-danger" %> ml-2"><%= google_connected? ? "連携済み" : "未連携" %></span>
      </div>
    </div>
    <div class="level-right">
      <div class="level-item">
        <% if google_connected? %>
          <form method="post" action="/settings/google/disconnect">
            <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
            <button type="submit" class="button is-light">連携を解除</button>
          </form>
        <% else %>
          <a class="button is-primary" href="/auth/google">Google と連携</a>
        <% end %>
      </div>
    </div>
  </div>
</div>

<h2 class="title is-5">スケジュール設定</h2>
<p class="block"><small>※ 営業時間・昼休憩などの時刻はすべて <strong><%= APP_TIMEZONE %></strong> として扱われます。</small></p>
<form method="post" action="/settings">
  <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">

  <div class="box">
    <h3 class="title is-6">MTG 調整可能な時間・曜日</h3>
    <p class="block"><small>この曜日・時間帯の範囲でのみ空き候補を表示します。</small></p>
    <div class="columns">
      <div class="column is-narrow">
        <div class="field">
          <label class="label">開始時刻</label>
          <div class="control">
            <input class="input" type="time" name="business_start" value="<%= @settings["business_start"] %>" required>
          </div>
        </div>
      </div>
      <div class="column is-narrow">
        <div class="field">
          <label class="label">終了時刻</label>
          <div class="control">
            <input class="input" type="time" name="business_end" value="<%= @settings["business_end"] %>" required>
          </div>
        </div>
      </div>
    </div>
    <div class="field">
      <label class="label">調整可能な曜日</label>
      <div class="control">
        <% FormatHelpers::WEEKDAY_ORDER.each do |wday| %>
          <label class="checkbox mr-4">
            <input type="checkbox" name="business_days[]" value="<%= wday %>"
                   <%= "checked" if @settings["business_days"].include?(wday) %>>
            <%= FormatHelpers::WEEKDAY_LABELS[wday] %>
          </label>
        <% end %>
      </div>
    </div>
  </div>

  <div class="box">
    <h3 class="title is-6">昼休憩の確保</h3>
    <p class="block"><small>この時間帯に連続した休憩（分）を確保できなくなる候補に「（ランチタイム）」を表示します。0 分で無効化できます。件名に「ランチ」「らんち」「lunch」を含む予定が当日の 10:00〜16:00 に既にある日は、その予定を昼休憩とみなし表示しません。</small></p>
    <div class="columns">
      <div class="column is-narrow">
        <div class="field">
          <label class="label">時間帯（開始）</label>
          <div class="control">
            <input class="input" type="time" name="lunch_start" value="<%= @settings["lunch_start"] %>" required>
          </div>
        </div>
      </div>
      <div class="column is-narrow">
        <div class="field">
          <label class="label">時間帯（終了）</label>
          <div class="control">
            <input class="input" type="time" name="lunch_end" value="<%= @settings["lunch_end"] %>" required>
          </div>
        </div>
      </div>
      <div class="column is-narrow">
        <div class="field">
          <label class="label">休憩時間（分）</label>
          <div class="control">
            <input class="input" type="number" name="lunch_minutes" value="<%= @settings["lunch_minutes"] %>" min="0" step="5" required>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="field">
    <div class="control">
      <button type="submit" class="button is-primary">保存</button>
    </div>
  </div>
</form>

<h2 class="title is-5 mt-6">他システム向け API キー</h2>
<p class="block"><small>同一マシン上の他システムからイベント一覧 API（<code>/api/v1/calendars/google/events</code>）を利用するためのキーです。キーは発行時に一度だけ表示され、サーバにはダイジェストのみ保存されます。</small></p>

<% if @new_api_key %>
  <div class="notification is-warning">
    <p>「<%= @new_api_key["label"] %>」の API キーを発行しました。以下のキーをコピーして利用するシステムに設定してください。<strong>この画面を離れると再表示できません。</strong></p>
    <p class="mt-2">
      <code id="new-api-key"><%= @new_api_key["key"] %></code>
      <button type="button" id="api-key-copy" data-target="new-api-key" class="button is-small ml-2">コピー</button>
    </p>
  </div>
<% end %>

<div class="box">
  <form method="post" action="/settings/api_keys">
    <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
    <div class="field has-addons">
      <div class="control">
        <input class="input" type="text" name="label" placeholder="システム名（例: sysA）"
               maxlength="<%= ApiHelpers::MAX_API_KEY_LABEL_LENGTH %>" required>
      </div>
      <div class="control">
        <button type="submit" class="button is-primary">発行</button>
      </div>
    </div>
  </form>

  <% api_keys = @settings["api_keys"] || {} %>
  <% if api_keys.any? %>
    <table class="table is-fullwidth mt-4">
      <thead>
        <tr><th>システム名</th><th>作成日時</th><th></th></tr>
      </thead>
      <tbody>
        <% api_keys.each do |label, info| %>
          <tr>
            <td><%= label %></td>
            <td><%= format_iso(info["created_at"]) %></td>
            <td class="has-text-right">
              <form method="post" action="/settings/api_keys/delete">
                <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
                <input type="hidden" name="label" value="<%= label %>">
                <button type="submit" class="button is-small is-light">削除</button>
              </form>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<script src="/settings.js"></script>
