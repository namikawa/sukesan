<div class="bar">
  <div class="brand">
    <span class="logo" aria-hidden="true">📅</span>
    <div class="titles">
      <h1>設定</h1>
      <p class="subtitle">SUKESAN</p>
    </div>
  </div>
  <form method="post" action="/settings/logout" class="inline">
    <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
    <button type="submit" class="btn ghost">ログアウト</button>
  </form>
</div>
<p><a href="/admin">← 管理画面に戻る</a></p>

<% if @flash %>
  <p class="flash"><%= @flash %></p>
<% end %>

<h2>Google カレンダー連携</h2>
<p class="note">ワンタイム URL の利用者は、ここで連携した管理者カレンダーに対して予定を登録します。</p>
<section class="connections">
  <div class="conn <%= google_connected? ? 'on' : 'off' %>">
    <span class="label">Google カレンダー</span>
    <span class="state"><%= google_connected? ? '連携済み' : '未連携' %></span>
  </div>
  <% if google_connected? %>
    <form method="post" action="/settings/google/disconnect" class="inline">
      <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
      <button type="submit" class="btn ghost">連携を解除</button>
    </form>
  <% else %>
    <a class="btn primary" href="/auth/google">Google と連携</a>
  <% end %>
</section>

<h2>スケジュール設定</h2>
<p class="note">※ 営業時間・昼休憩などの時刻はすべて <strong><%= APP_TIMEZONE %></strong> として扱われます。</p>
<form method="post" action="/settings" class="settings-form">
  <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">

  <fieldset class="settings-group">
    <legend>MTG 調整可能な時間・曜日</legend>
    <p class="note">この曜日・時間帯の範囲でのみ空き候補を表示します。</p>
    <div class="field-row">
      <label>開始時刻
        <input type="time" name="business_start" value="<%= @settings["business_start"] %>" required>
      </label>
      <label>終了時刻
        <input type="time" name="business_end" value="<%= @settings["business_end"] %>" required>
      </label>
    </div>
    <div class="field-row">
      <span class="field-label">調整可能な曜日</span>
      <div class="weekdays">
        <% WEEKDAY_ORDER.each do |wday| %>
          <label class="weekday">
            <input type="checkbox" name="business_days[]" value="<%= wday %>"
                   <%= "checked" if @settings["business_days"].include?(wday) %>>
            <%= WEEKDAY_LABELS[wday] %>
          </label>
        <% end %>
      </div>
    </div>
  </fieldset>

  <fieldset class="settings-group">
    <legend>昼休憩の確保</legend>
    <p class="note">この時間帯に連続した休憩（分）を確保できなくなる候補に「（ランチタイム）」を表示します。0 分で無効化できます。</p>
    <div class="field-row">
      <label>時間帯（開始）
        <input type="time" name="lunch_start" value="<%= @settings["lunch_start"] %>" required>
      </label>
      <label>時間帯（終了）
        <input type="time" name="lunch_end" value="<%= @settings["lunch_end"] %>" required>
      </label>
      <label>休憩時間（分）
        <input type="number" name="lunch_minutes" value="<%= @settings["lunch_minutes"] %>" min="0" step="5" required>
      </label>
    </div>
  </fieldset>


  <button type="submit" class="btn primary">保存</button>
</form>

<h2>Outlook 同期</h2>
<p class="note"><a href="/sync">Outlook 側にのみある予定を Google へ反映するツール</a>（管理者専用）。</p>
