<nav class="level app-header">
  <div class="level-left">
    <div class="level-item">
      <div class="is-flex is-align-items-center">
        <span class="app-logo" aria-hidden="true">📅</span>
        <div class="ml-3">
          <h1 class="title is-4 mb-1">スケジュール同期ツール</h1>
          <p class="subtitle is-6 mb-0">SUKESAN</p>
        </div>
      </div>
    </div>
  </div>
  <div class="level-right">
    <div class="level-item">
      <form method="post" action="/settings/logout">
        <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
        <button type="submit" class="button is-light">ログアウト</button>
      </form>
    </div>
  </div>
</nav>
<p class="block"><a href="/admin">← 管理者トップ</a></p>

<p class="block">Outlook 側にのみ存在するイベントを検知し、選択したものを Google カレンダーへ反映します。</p>

<% if @flash %>
  <div class="notification is-info is-light"><%= @flash %></div>
<% end %>

<div class="box">
  <div class="is-flex is-flex-wrap-wrap is-align-items-center">
    <span class="mr-4">Google カレンダー
      <span class="tag <%= google_connected? ? "is-success" : "is-danger" %>"><%= google_connected? ? "連携済み" : "未連携" %></span>
    </span>
    <% unless google_connected? %>
      <a class="button is-small mr-4" href="/settings">設定で連携</a>
    <% end %>
    <span class="mr-4">MS Outlook
      <span class="tag <%= microsoft_connected? ? "is-success" : "is-danger" %>"><%= microsoft_connected? ? "連携済み" : "未連携" %></span>
    </span>
    <% unless microsoft_connected? %>
      <a class="button is-small mr-4" href="/auth/microsoft">Outlook と連携</a>
    <% end %>
    <% if microsoft_connected? %>
      <form method="post" action="/disconnect">
        <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
        <button type="submit" class="button is-small is-light">Outlook 連携を解除</button>
      </form>
    <% end %>
  </div>
</div>

<% if google_connected? && microsoft_connected? %>
  <form method="post" action="/check" class="box">
    <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
    <h2 class="title is-6">取得範囲（Google・Outlook 共通）</h2>
    <p class="block is-size-7 has-text-grey">Google・Outlook の両方から、指定した範囲の予定を取得して差分を照合します。</p>

    <div class="sync-line mb-2">
      <label class="radio">
        <input type="radio" name="range_mode" value="days" checked>
        日数で指定:
      </label>
      <input class="input is-small input-days" type="number" name="sync_window_days"
             value="<%= @settings["sync_window_days"] %>" min="1" max="180" step="1">
      <span>日先まで（当日 0:00 起点・最大 180）</span>
    </div>

    <div class="sync-line mb-3">
      <label class="radio">
        <input type="radio" name="range_mode" value="range">
        日付範囲で指定:
      </label>
      <input class="input is-small input-auto" type="date" name="start_date">
      <span>〜</span>
      <input class="input is-small input-auto" type="date" name="end_date">
      <span>（最大 180 日）</span>
    </div>

    <label class="checkbox mb-3">
      <input type="checkbox" name="test_mode" value="1">
      テストモード（差分の表示のみ・Google には反映しない）
    </label>

    <div>
      <button type="submit" class="button is-primary">2つのカレンダーをチェック</button>
    </div>
  </form>
<% else %>
  <p class="block has-text-grey">Google と Outlook の両方を連携するとチェックできます。</p>
<% end %>

<% if @events.any? && @test_mode %>
  <div class="notification is-warning">テストモード: 以下は差分のプレビューです（Google には反映されません）。反映するにはテストモードを外して再チェックしてください。</div>
  <table class="table is-fullwidth is-hoverable">
    <thead>
      <tr><th>件名</th><th>開始</th><th>終了</th><th>場所</th></tr>
    </thead>
    <tbody>
      <% @events.each do |event| %>
        <tr>
          <td><%= event.title %></td>
          <td><%= format_dt(event.starts_at, all_day: event.all_day) %></td>
          <td><%= format_dt(event.ends_at, all_day: event.all_day) %></td>
          <td><%= event.location %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% elsif @events.any? %>
  <form method="post" action="/sync" id="sync-form">
    <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
    <table class="table is-fullwidth is-hoverable">
      <thead>
        <tr>
          <th><input type="checkbox" id="select-all" aria-label="すべて選択"></th>
          <th>件名</th>
          <th>開始</th>
          <th>終了</th>
          <th>場所</th>
        </tr>
      </thead>
      <tbody>
        <% @events.each do |event| %>
          <tr>
            <td><input type="checkbox" name="selected[]" value="<%= event.external_id %>"></td>
            <td><%= event.title %></td>
            <td><%= format_dt(event.starts_at, all_day: event.all_day) %></td>
            <td><%= format_dt(event.ends_at, all_day: event.all_day) %></td>
            <td><%= event.location %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <button type="submit" class="button is-primary">選択したイベントを Google に同期</button>
  </form>
<% elsif @checked %>
  <div class="notification is-info">指定範囲で Outlook 側にのみ存在するイベントはありませんでした（同期の必要はありません）。</div>
<% else %>
  <p class="block has-text-grey">取得範囲を指定して「2つのカレンダーをチェック」を押すと、Outlook 側にのみ存在するイベントが一覧表示されます。</p>
<% end %>

<script src="/sync.js"></script>
