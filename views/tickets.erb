<%== page_header(title: "Google カレンダー調整ツール", logout: true) %>
<nav class="level is-mobile mb-3">
  <div class="level-left">
    <nav class="breadcrumb mb-0" aria-label="breadcrumbs">
      <ul>
        <li><a href="/">トップ</a></li>
        <li><a href="/admin">管理者トップ</a></li>
        <li class="is-active"><a href="#" aria-current="page">Google カレンダー調整ツール</a></li>
      </ul>
    </nav>
  </div>
  <div class="level-right">
    <div class="level-item"><a href="/settings">⚙ 設定</a></div>
  </div>
</nav>

<%== flash_messages %>

<h2 class="title is-5">Google カレンダー登録用ワンタイム URL</h2>
<p class="block">調整したい相手に渡す「1 回限り・24 時間有効」の URL を発行します。1 度予定が登録されると、その URL は使えなくなります。</p>
<form method="post" action="/tickets">
  <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
  <button type="submit" class="button is-primary"<%= " disabled" unless google_connected? %>>新しいワンタイム URL を発行</button>
</form>
<% unless google_connected? %>
  <p class="block mt-2 is-size-7 has-text-grey">※ URL を発行するには、先に <a href="/settings">設定画面</a>で Google カレンダーと連携してください。</p>
<% end %>

<% if @total > 0 %>
  <div class="box mt-4">
    <div class="level is-mobile mb-3">
      <div class="level-left">
        <div class="level-item"><%= @total %> 件中 <%= (@page - 1) * @per + 1 %>–<%= [@page * @per, @total].min %> 件を表示</div>
      </div>
      <div class="level-right">
        <div class="level-item">
          <form method="get" action="/tickets" class="pager-per is-flex is-align-items-center">
            <label class="mr-2" for="per">表示件数</label>
            <div class="select is-small mr-2">
              <select id="per" name="per" class="per-select">
                <% PER_PAGE_OPTIONS.each do |opt| %>
                  <option value="<%= opt %>"<%= " selected" if opt == @per %>><%= opt %> 件</option>
                <% end %>
              </select>
            </div>
            <button type="submit" class="button is-small">表示</button>
          </form>
        </div>
      </div>
    </div>

    <table class="table is-fullwidth is-hoverable">
      <thead>
        <tr>
          <th>ステータス</th>
          <th>発行日時</th>
          <th>URL / 登録内容</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% @tickets.each do |ticket| %>
          <% st = TicketStore.status(ticket) %>
          <% field_id = "ticket-url-#{ticket["token"]}" %>
          <%# cancelled は修飾なし（既定のグレー）: is-light はテーマによって背景と同化して読めないため。 %>
          <% tag_class = { "active" => "is-success", "used" => "is-info", "expired" => "is-warning",
                           "revoked" => "is-danger", "held" => "is-link", "cancelled" => "" }[st] %>
          <tr>
            <td><span class="tag <%= tag_class %>"><%= ticket_status_label(ticket) %></span></td>
            <td class="is-size-7 has-text-grey"><%= format_iso(ticket["created_at"]) %></td>
            <td>
              <% if st == "active" %>
                <input id="<%= field_id %>" class="input is-small ticket-url" type="text" value="<%= ticket_url(ticket["token"]) %>" readonly>
              <% elsif st == "used" %>
                <span class="is-size-7">
                  <%= ticket["requester"] %> /「<%= ticket["title"] %>」/
                  <%= format_slot_range(ticket["slot_start"], ticket["slot_end"]) %>
                  （登録: <%= format_iso(ticket["used_at"]) %>）
                </span>
              <% elsif st == "held" %>
                <span class="is-size-7">
                  <%= ticket["requester"] %> /「<%= ticket["title"] %>」/
                  仮押さえ 残 <%= Array(ticket["holds"]).size %> 件
                  （期限: <%= format_dt(Time.iso8601(ticket["held_at"]) + TicketStatus::HOLD_TTL_SECONDS) %>）
                </span>
                <ul class="is-size-7 hold-slot-list">
                  <% Array(ticket["holds"]).sort_by { |h| h["slot_start"] }.each do |hold| %>
                    <li><%= format_slot_range(hold["slot_start"], hold["slot_end"]) %></li>
                  <% end %>
                </ul>
              <% else %>
                <span class="has-text-grey">—</span>
              <% end %>
            </td>
            <td class="ticket-actions">
              <% if st == "active" || st == "held" %>
                <% if st == "active" %>
                  <button type="button" class="button is-small copy-btn" data-target="<%= field_id %>">コピー</button>
                <% end %>
                <form method="post" action="/tickets/<%= ticket["token"] %>/revoke" class="is-inline">
                  <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
                  <button type="submit" class="button is-small is-light">無効化</button>
                </form>
              <% else %>
                —
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @total_pages > 1 %>
      <nav class="pager level is-mobile" aria-label="ページ送り">
        <div class="level-left">
          <% if @page > 1 %>
            <a class="button is-small" href="/tickets?page=<%= @page - 1 %>&per=<%= @per %>">← 前へ</a>
          <% else %>
            <button class="button is-small" disabled>← 前へ</button>
          <% end %>
        </div>
        <div class="level-item"><%= @page %> / <%= @total_pages %> ページ</div>
        <div class="level-right">
          <% if @page < @total_pages %>
            <a class="button is-small" href="/tickets?page=<%= @page + 1 %>&per=<%= @per %>">次へ →</a>
          <% else %>
            <button class="button is-small" disabled>次へ →</button>
          <% end %>
        </div>
      </nav>
    <% end %>
  </div>
<% else %>
  <p class="block has-text-grey">まだ発行済みの URL はありません。</p>
<% end %>

<script src="/admin.js"></script>
