<div class="bar">
  <h1>管理画面</h1>
  <form method="post" action="/settings/logout" class="inline">
    <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
    <button type="submit" class="btn ghost">ログアウト</button>
  </form>
</div>
<p class="nav-links">
  <a href="/">← トップページ</a>
  <a href="/settings">設定画面へ →</a>
</p>

<% if @flash %>
  <p class="flash"><%= @flash %></p>
<% end %>

<h2>ワンタイム URL</h2>
<p class="note">調整したい相手に渡す「1 回限り・24 時間有効」の URL を発行します。1 度予定が登録されると、その URL は使えなくなります。</p>
<form method="post" action="/tickets" class="inline">
  <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
  <button type="submit" class="btn primary"<%= " disabled" unless google_connected? %>>新しい URL を発行</button>
</form>
<% unless google_connected? %>
  <p class="note">※ URL を発行するには、先に <a href="/settings">設定画面</a>で Google カレンダーと連携してください。</p>
<% end %>

<% if @tickets.any? %>
  <table class="tickets">
    <thead>
      <tr>
        <th class="col-status">ステータス</th>
        <th class="col-created">発行日時</th>
        <th>URL / 登録内容</th>
        <th class="col-actions">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @tickets.each do |ticket| %>
        <% st = TicketStore.status(ticket) %>
        <% field_id = "ticket-url-#{ticket["token"]}" %>
        <tr class="ticket-<%= st %>">
          <td><span class="status status-<%= st %>"><%= ticket_status_label(ticket) %></span></td>
          <td class="col-created"><%= format_iso(ticket["created_at"]) %></td>
          <td>
            <% if st == "active" %>
              <input id="<%= field_id %>" class="ticket-url" type="text" value="<%= ticket_url(ticket["token"]) %>" readonly>
            <% elsif st == "used" %>
              <span class="ticket-detail">
                <%= ticket["requester"] %> /「<%= ticket["title"] %>」/
                <%= format_slot_range(ticket["slot_start"], ticket["slot_end"]) %>
                （登録: <%= format_iso(ticket["used_at"]) %>）
              </span>
            <% else %>
              <span class="ticket-detail">—</span>
            <% end %>
          </td>
          <td class="col-actions">
            <% if st == "active" %>
              <div class="row-actions">
                <button type="button" class="btn small copy-btn" data-target="<%= field_id %>">コピー</button>
                <form method="post" action="/tickets/<%= ticket["token"] %>/revoke" class="inline">
                  <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
                  <button type="submit" class="btn small ghost">無効化</button>
                </form>
              </div>
            <% else %>
              —
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="note">まだ発行済みの URL はありません。</p>
<% end %>

<script src="/admin.js"></script>
