<div class="bar">
  <div class="brand">
    <span class="logo" aria-hidden="true">📅</span>
    <div class="titles">
      <h1>管理者トップ</h1>
      <p class="subtitle">SUKESAN</p>
    </div>
  </div>
  <form method="post" action="/settings/logout" class="inline">
    <input type="hidden" name="authenticity_token" value="<%= csrf_token %>">
    <button type="submit" class="btn ghost">ログアウト</button>
  </form>
</div>
<p class="nav-links">
  <a href="/">← トップページ</a>
</p>

<% if @flash %>
  <p class="flash"><%= @flash %></p>
<% end %>

<section class="admin-menu">
  <a class="menu-card" href="/tickets">
    <span class="menu-title">Google カレンダー調整ツール</span>
    <span class="menu-desc">調整用のワンタイム URL を発行・管理します。</span>
  </a>
  <a class="menu-card" href="/sync">
    <span class="menu-title">スケジュール同期ツール</span>
    <span class="menu-desc">Outlook 側にのみある予定を Google カレンダーへ同期します。</span>
  </a>
</section>
