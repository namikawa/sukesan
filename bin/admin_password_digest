#!/usr/bin/env ruby
# frozen_string_literal: true

# 管理者パスワードの bcrypt ダイジェストを生成する。
# 出力された行を .env に貼り付けて使う（平文は保存しない）。
#
# 使い方:
#   bin/admin_password_digest
#   プロンプトにパスワードを入力する（エコーされないためシェル履歴にも残らない）。

require "bundler/setup"
require "bcrypt"
require "io/console"

def prompt(message)
  print message
  # 端末ではエコーを抑止する（履歴・肩越しの覗き見対策）。非対話実行時は通常入力にフォールバック。
  raw = $stdin.tty? ? $stdin.noecho(&:gets) : $stdin.gets
  puts
  raw.to_s.chomp
end

password = prompt("管理者パスワードを入力: ")
confirm = prompt("確認のためもう一度入力: ")

if password.empty?
  warn "パスワードが空です。中止しました。"
  exit 1
end

unless password == confirm
  warn "パスワードが一致しません。中止しました。"
  exit 1
end

puts
puts "以下を .env に設定してください（$ を含むため必ずシングルクォートで囲む）:"
puts "ADMIN_PASSWORD_DIGEST='#{BCrypt::Password.create(password)}'"
